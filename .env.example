# ════════════════════════════════════════════════════════════════════════════
# flowers environment — copy to `.env` and fill in. NEVER commit `.env` (gitignored).
#
# Every adapter is GATED: if its key is unset (or FLOWERS_FORCE_OFFLINE=1), flowers silently uses the
# offline Fake for that seam. Fill these in incrementally — nothing breaks while a key is blank, and the
# whole offline test suite runs at $0 with everything blank.
# ════════════════════════════════════════════════════════════════════════════

# ── CORE LOOP — model + search + per-user OAuth integrations ──────────────────
OPENROUTER_API_KEY=        # LLM gateway (planner + executor).  https://openrouter.ai/settings/keys  (sk-or-v1-…)
TAVILY_API_KEY=            # primary web search.                 https://app.tavily.com               (tvly-…)
ARCADE_API_KEY=            # per-user OAuth integrations.        https://api.arcade.dev/dashboard     (arc_…)
#                          # Gmail send + Google Calendar. Arcade "dev mode" connects YOUR OWN Google account.

# ── BROWSER — no-API last-mile (off by default; set BOTH to enable) ──────────
BROWSERBASE_API_KEY=       # browserbase.com → Overview, right panel              (bb_…)
BROWSERBASE_PROJECT_ID=    # SAME panel — per-project UUID (BOTH required)

# ── RUNTIME ──────────────────────────────────────────────────────────────────
# FLOWERS_USER_ID=you@example.com     # identity handed to per-user seams (Arcade OAuth user). REQUIRED in
#                                     # Arcade "dev mode": must be your Arcade account email, or every
#                                     # connect fails with user_mismatch. Default: "local".
FLOWERS_DB=flowers.db                 # sqlite store path (default)
FLOWERS_TIMERS_DB=flowers_timers.db   # sqlite durable-timers path (default)
FLOWERS_TICK_SECONDS=15               # durable-timer poll cadence (0 disables the background poller)
# FLOWERS_FORCE_OFFLINE=1             # pin every adapter offline (the test suite sets this; $0, no network)
# FLOWERS_SEND_PREVIEW=always         # owner-grant sends: "always" (default) previews the outgoing draft as
#                                     # the single confirm; "never" sends directly (zero touches)
# FLOWERS_FAST_PATH=on                # single-action fast path: a self-contained "email X saying Y" skips
#                                     # the clarifier + planner (~5 -> <=2 model calls); "off" disables
# FLOWERS_ESCALATION_TTL_H=24         # hours an unanswered escalation may sit before the reaper closes it
# FLOWERS_VERIFY_ATTEMPTS=4           # read-back polls per effect when a live provider is wired (lag
# FLOWERS_VERIFY_DELAY=1.5            # tolerance for e.g. Gmail's Sent label); offline defaults are 1 / 0
# FLOWERS_REPLY_STYLE=                # optional owner-facing voice appended to executor/clarifier/chat
#                                     # prompts (e.g. a chat front end keeps replies text-message-short)

# ── OPTIONAL ADAPTERS (flowers/extras/ — not wired by default; swap into build_app) ──
# FLOWERS_DATABASE_URL=    # Postgres DSN for the optional PostgresStore (use your own Postgres instead of sqlite)
# E2B_API_KEY=             # microVM sandbox for the optional E2BSandbox.  e2b.dev/dashboard?tab=keys   (e2b_…)
# LANGFUSE_PUBLIC_KEY=     # telemetry for the optional LangfuseTracer.  cloud.langfuse.com → Settings   (pk-lf-…)
# LANGFUSE_SECRET_KEY=     # shown ONCE at creation — copy immediately                                  (sk-lf-…)
# LANGFUSE_HOST=https://cloud.langfuse.com   # EU default; us.cloud.langfuse.com if you signed up US (must match)
# BRAVE_API_KEY=           # search fallback for the optional BraveSearch adapter (wrap with FallbackSearch)
